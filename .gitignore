# ==========================================
# KiCad Project Git Ignore Rules
# ==========================================

# --- KiCad Backup and Autosave Files ---
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*.sch-bak
*~
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
*.lck
ipradio-backups

# --- Local User Settings and Caches ---
# Contains your personal window positions, visible layers, and local paths
*.kicad_prl
fp-info-cache

# --- Generated Manufacturing Outputs (Optional but recommended) ---
# Uncomment these if you generate plots/Gerbers inside the project folder 
# and do not want to track them in version control.
# /bom/
# /gerbers/
# /jlcpcb/

# --- Simulation and Design Outputs ---
*.net
*.dsn
*.ses
*.cmp
*.xml
*.csv
*.tsv

# --- Log and Diagnostic Files ---
*.log
*.raw
.svg2shenzhen-cache
